<!doctype html>
<html lang="en">
  <head>
    <title>About Us</title>

    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="/css/styles.css"
    />
  </head>

  <body>
    <div class="wrapper">
      <nav
        class="navbar navbar-expand-lg navbar-dark bg-primary"
      >
        <div class="container">
          <a
            class="navbar-brand d-flex align-items-center"
            href="/"
          >
            <img
              src="/images/logo.png"
              alt="photo"
              width="40"
              height="40"
              class="me-2"
            />
            <span>ABC College</span>
          </a>

          <button
            class="navbar-toggler"
            data-bs-toggle="collapse"
            data-bs-target="#menu"
          >
            <span
              class="navbar-toggler-icon"
            ></span>
          </button>

          <div
            class="collapse navbar-collapse"
            id="menu"
          >
            <ul
              class="navbar-nav ms-auto"
            >
              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/"
                >
                  Home
                </a>
              </li>

              <li class="nav-item">
                <a
                  class="nav-link active"
                  href="/about"
                >
                  About
                </a>
              </li>

              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/departments"
                >
                  Departments
                </a>
              </li>

              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/courses"
                >
                  Courses
                </a>
              </li>

              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/gallery"
                >
                  Gallery
                </a>
              </li>

              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/contact"
                >
                  Contact
                </a>
              </li>
            </ul>
          </div>
        </div>
      </nav>

      <main class="content">
        <section
          class="about-banner text-center text-white py-0"
        >
          <div class="container">
            <h1 class="mb-1">
              About Our College
            </h1>

            <p class="mb-0">
              Empowering students
              through quality education.
            </p>
          </div>
        </section>

        <!-- About Section -->

        <section class="container py-3">
          <div
            class="row align-items-center g-4"
          >
            <div class="col-md-6">
              <img
                src="images/about.jpg"
                class="img-fluid rounded shadow"
                alt="College"
              />
            </div>

            <div class="col-md-6">
              <h2>Who We Are</h2>

              <p>
                ABC College was
                established in 2000 with
                the vision of providing
                quality education and
                developing skilled
                professionals for the
                future.
              </p>

              <p>
                Our institution offers
                modern laboratories,
                experienced faculty
                members, excellent
                placements, and advanced
                learning facilities.
              </p>
            </div>
          </div>
        </section>

        <!-- Vision and Mission -->

        <section class="container py-3">
          <div class="row g-4">
            <div class="col-md-6">
              <div
                class="card p-4 text-center"
              >
                <h3>Our Vision</h3>

                <p>
                  To become a center of
                  excellence in
                  education, innovation,
                  and research.
                </p>
              </div>
            </div>

            <div class="col-md-6">
              <div
                class="card p-4 text-center"
              >
                <h3>Our Mission</h3>

                <p>
                  To provide quality
                  education and prepare
                  students for
                  successful careers and
                  lifelong learning.
                </p>
              </div>
            </div>
          </div>
        </section>

        <section class="container py-3">
          <h2 class="text-center mb-4">
            College Statistics
          </h2>

          <div
            class="row text-center g-4"
          >
            <div class="col-md-3">
              <div class="card p-4">
                <h2>5000+</h2>

                <p>Students</p>
              </div>
            </div>

            <div class="col-md-3">
              <div class="card p-4">
                <h2>200+</h2>

                <p>Faculty</p>
              </div>
            </div>

            <div class="col-md-3">
              <div class="card p-4">
                <h2>20+</h2>

                <p>Departments</p>
              </div>
            </div>

            <div class="col-md-3">
              <div class="card p-4">
                <h2>95%</h2>

                <p>Placements</p>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer
        class="bg-dark text-white text-center p-3 mt-auto"
      >
        <p>
          © 2026 ABC College. All Rights
          Reserved.
        </p>

        <div class="mt-2">
          <a
            href="https://github.com/mpujitha2006-sys"
            target="_blank"
            class="text-white me-3"
          >
            <i
              class="fab fa-github fa-2x"
            ></i>
          </a>

          <a
            href="https://www.linkedin.com/in/pujitha-mogallapalli-15504532b"
            target="_blank"
            class="text-white"
          >
            <i
              class="fab fa-linkedin fa-2x"
            ></i>
          </a>
          <a
            href="/admin-login"
            class="text-white text-decoration-none ms-3"
            >Admin Login</a
          >
        </div>
      </footer>
    </div>

    <script src="js/script.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
