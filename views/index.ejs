<!doctype html>

<html lang="en">
  <head>
    <title>ABC College</title>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="/css/styles.css"
    />
  </head>
  <body>
    <div class="wrapper">
      <nav
        class="navbar navbar-expand-lg navbar-dark bg-primary"
      >
        <div class="container">
          <a
            class="navbar-brand d-flex align-items-center"
            href="/"
          >
            <img
              src="/images/logo.png"
              alt="photo"
              width="40"
              height="40"
              class="me-2"
            />
            <span>ABC College</span>
          </a>
          <button
            class="navbar-toggler"
            data-bs-toggle="collapse"
            data-bs-target="#menu"
          >
            <span
              class="navbar-toggler-icon"
            ></span>
          </button>

          <div
            class="collapse navbar-collapse"
            id="menu"
          >
            <ul
              class="navbar-nav ms-auto"
            >
              <li class="nav-item">
                <a
                  class="nav-link active"
                  href="/"
                  >Home</a
                >
              </li>
              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/about"
                  >About</a
                >
              </li>
              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/departments"
                  >Departments</a
                >
              </li>
              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/courses"
                  >Courses</a
                >
              </li>
              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/gallery"
                  >Gallery</a
                >
              </li>
              <li class="nav-item">
                <a
                  class="nav-link"
                  href="/contact"
                  >Contact</a
                >
              </li>
            </ul>
          </div>
        </div>
      </nav>
      <main class="content">
        <section class="hero">
          <div
            class="container text-center text-white"
          >
            <h1>
              Welcome to ABC College
            </h1>
            <p>
              Empowering Students for
              the Future
            </p>
          </div>
        </section>

        <section class="container py-3">
          <h2 class="text-center mb-4">
            Why Choose Us?
          </h2>

          <div class="row g-4">
            <div class="col-md-4">
              <div class="card p-4">
                <h4>
                  Experienced Faculty
                </h4>
                <p>
                  Highly qualified
                  professors.
                </p>
              </div>
            </div>

            <div class="col-md-4">
              <div class="card p-4">
                <h4>Modern Labs</h4>
                <p>
                  Advanced
                  infrastructure and
                  labs.
                </p>
              </div>
            </div>

            <div class="col-md-4">
              <div class="card p-4">
                <h4>Placements</h4>
                <p>
                  Excellent placement
                  opportunities.
                </p>
              </div>
            </div>
          </div>
        </section>
        <section class="container py-5">
          <h2 class="text-center mb-4">
            College Statistics
          </h2>

          <div
            class="row text-center g-4"
          >
            <div class="col-md-4">
              <div class="card p-4">
                <h3>5000+</h3>
                <p>Students</p>
              </div>
            </div>

            <div class="col-md-4">
              <div class="card p-4">
                <h3>200+</h3>
                <p>Faculty</p>
              </div>
            </div>

            <div class="col-md-4">
              <div class="card p-4">
                <h3>20+</h3>
                <p>Departments</p>
              </div>
            </div>

            <div class="col-md-4">
              <div class="card p-4">
                <h3>95%</h3>
                <p>Placements</p>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer
        class="bg-dark text-white text-center p-3 mt-auto"
      >
        <p>
          © 2026 ABC College. All Rights
          Reserved.
        </p>

        <div class="mt-2">
          <a
            href="https://github.com/mpujitha2006-sys"
            target="_blank"
            class="text-white me-3"
          >
            <i
              class="fab fa-github fa-2x"
            ></i>
          </a>

          <a
            href="https://www.linkedin.com/in/pujitha-mogallapalli-15504532b"
            target="_blank"
            class="text-white"
          >
            <i
              class="fab fa-linkedin fa-2x"
            ></i>
          </a>
          <a
            href="/admin-login"
            class="text-white text-decoration-none ms-3"
            >Admin Login</a
          >
        </div>
      </footer>
    </div>
    <script src="/js/script.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
